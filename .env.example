# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-uuid-here"
NEXTAUTH_URL="http://localhost:3000"

# Gemini AI
GEMINI_API_KEY="your_gemini_api_key"

# Finance Hub (Optional)
GROWW_API_KEY=your_groww_key_here
GROWW_API_SECRET=your_groww_secret_here

# Weather Intelligence
WEATHER_API_KEY=your_weatherapi_key_here

# Zomato Intelligence Hub (Optional)
ZOMATO_CLIENT_ID=your_client_id_here
ZOMATO_CLIENT_SECRET=your_client_secret_here
