# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database files
*.db
prisma/dev.db

# sensitive files
client_secret_*.json

# logs and temp files
build.log
server.log
err_dump.txt
test_res.txt

# temp/test files
test-db.ts
tmp_check_db.ts
/tmp/
/tmp_prisma/
/scripts/

# gemini
.gemini/
