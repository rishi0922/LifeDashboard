generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  points          Int       @default(0)
  tier            String    @default("Bronze")
  streak          Int       @default(0)
  tasks           Task[]
  notes           Note[]
  foodOrders      FoodOrder[]
  preferences     UserPreference[]
  expenses        Expense[]
  processedEmails ProcessedEmail[]
}

model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  category      String   @default("Work")
  status        String   @default("TODO")
  isAiGenerated Boolean  @default(false)
  externalId    String?  @unique
  deadline      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodOrder {
  id          String   @id @default(cuid())
  restaurant  String
  items       String
  cost        Float
  status      String   @default("Preparing") // Preparing, On the Way, Delivered
  etaMinutes  Int?
  externalId  String?  @unique
  source      String   @default("Local")      // Local, Zomato
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id        String   @id @default(cuid())
  key       String   // e.g. "favorite_cuisine"
  value     String   // e.g. "Italian"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  merchant    String
  category    String   // Food, Travel, Bills, Shopping, Entertainment, Investment, Health, Groceries, Subscription, Transfer, Other
  subcategory String?  // dining_out, ride_hailing, ott_subscription, utility_bill, upi_transfer, etc.
  description String?  // Original email snippet / manual note
  paymentMode String?  // UPI, CARD, NETBANKING, CASH, WALLET
  confidence  Float?   // 0..1 classifier confidence
  method      String?  // "rule" | "ai" | "manual" — how this was categorized
  date        DateTime @default(now())
  sourceId    String?  @unique
  sourceType  String?  // GMAIL, MANUAL
  fingerprint String?  // hash(userId + normalizedMerchant + amount + date) for cross-email dedup
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, fingerprint])
}

/// Persistent record of every Gmail message we've touched, so repeat syncs
/// never re-process the same email. This is the backbone of idempotency for
/// both the calendar-event pipeline and the expense-extraction pipeline.
model ProcessedEmail {
  id          String   @id @default(cuid())
  emailId     String   // Gmail message ID
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose     String   // "inbox_sync" | "finance_sync"
  outcome     String   // "task" | "event" | "expense" | "ignored" | "error"
  externalRef String?  // Google Calendar event ID, Task ID, or Expense ID
  subject     String?
  snippet     String?
  processedAt DateTime @default(now())

  @@unique([userId, emailId, purpose])
  @@index([userId, processedAt])
}